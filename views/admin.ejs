<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Contact submissions — Auspico Admin</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&display=swap" rel="stylesheet" />
  <style>
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: 'DM Sans', system-ui, sans-serif;
      background: #f5f5f0;
      color: #1a1210;
      padding: 1.5rem;
      font-size: 15px;
    }
    .admin-wrap { max-width: 1000px; margin: 0 auto; }
    h1 {
      font-size: 1.5rem;
      font-weight: 700;
      margin: 0 0 0.5rem;
    }
    .meta {
      color: #5c4a42;
      margin-bottom: 1.5rem;
      font-size: 0.9rem;
    }
    .back {
      display: inline-block;
      margin-bottom: 1rem;
      color: #1a1210;
      font-weight: 500;
      text-decoration: none;
    }
    .back:hover { text-decoration: underline; }
    .empty {
      background: #fff;
      padding: 2rem;
      border-radius: 12px;
      text-align: center;
      color: #5c4a42;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      background: #fff;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    }
    th, td {
      padding: 0.85rem 1rem;
      text-align: left;
      border-bottom: 1px solid #eee;
    }
    th {
      background: #1a1210;
      color: #fff;
      font-weight: 600;
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: #fafaf8; }
    .msg { max-width: 280px; word-break: break-word; }
    .date { font-size: 0.85rem; color: #5c4a42; white-space: nowrap; }
    a.mail { color: #1a1210; text-decoration: none; }
    a.mail:hover { text-decoration: underline; }
    @media (max-width: 768px) {
      table, th, td { display: block; }
      th { display: none; }
      tr { border: 1px solid #eee; margin-bottom: 1rem; border-radius: 8px; padding: 1rem; background: #fff; }
      td { border: none; padding: 0.35rem 0; }
      td::before {
        content: attr(data-label);
        font-weight: 600;
        display: inline-block;
        min-width: 80px;
        margin-right: 0.5rem;
      }
      .msg { max-width: 100%; }
    }
  </style>
</head>
<body>
  <div class="admin-wrap">
    <a href="/" class="back">← Back to site</a>
    <h1>Contact form submissions</h1>
    <p class="meta">Total: <%= total %> (newest first). Data is in memory and resets when the server restarts.</p>

    <% if (submissions.length === 0) { %>
      <div class="empty">No submissions yet.</div>
    <% } else { %>
      <table>
        <thead>
          <tr>
            <th>Date</th>
            <th>Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Message</th>
          </tr>
        </thead>
        <tbody>
          <% submissions.forEach(function(s) { %>
            <tr>
              <td data-label="Date" class="date"><%= new Date(s.createdAt).toLocaleString('en-IN', { dateStyle: 'short', timeStyle: 'short' }) %></td>
              <td data-label="Name"><%= s.name %></td>
              <td data-label="Email"><a href="mailto:<%= s.email %>" class="mail"><%= s.email %></a></td>
              <td data-label="Phone"><%= s.phone || '—' %></td>
              <td data-label="Message" class="msg"><%= s.message %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    <% } %>
  </div>
</body>
</html>
